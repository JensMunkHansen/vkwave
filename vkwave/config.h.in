#pragma once

#define SPDLOG_ACTIVE_LEVEL SPDLOG_LEVEL_TRACE

// Note: VULKAN_HPP_DISPATCH_LOADER_DYNAMIC=1 is defined via CMakeLists.txt
// to ensure it's defined before any vulkan.hpp includes in all translation units

#define SHADER_DIR "@CMAKE_CURRENT_SOURCE_DIR@/shaders/"

// VKWAVE_DEBUG is NOT defined here: with a multi-config generator config.h is
// generated once and shared across configs, so it cannot vary per-config. It is
// instead a per-config compile definition ($<$<CONFIG:Debug>:VKWAVE_DEBUG>) in
// vkwave/CMakeLists.txt — defined for Debug, undefined for Release.
